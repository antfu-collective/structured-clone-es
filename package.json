{
  "name": "structured-clone-es",
  "type": "module",
  "version": "1.0.0",
  "packageManager": "pnpm@10.32.1",
  "description": "A re-distribution of @ungap/structured-clone for Node.js compatible ES Modules",
  "author": "Andrea Giammarchi",
  "license": "ISC",
  "homepage": "https://github.com/antfu-collective/structured-clone-es#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/antfu-collective/structured-clone-es.git"
  },
  "bugs": "https://github.com/antfu-collective/structured-clone-es/issues",
  "keywords": [],
  "sideEffects": false,
  "exports": {
    ".": "./dist/index.mjs"
  },
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "unbuild",
    "dev": "unbuild --stub",
    "lint": "eslint .",
    "prepublishOnly": "nr build",
    "release": "bumpp",
    "start": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "prepare": "simple-git-hooks"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^7.7.2",
    "@antfu/ni": "^28.3.0",
    "@antfu/utils": "^9.3.0",
    "@types/node": "^25.4.0",
    "@types/ungap__structured-clone": "^1.2.0",
    "@ungap/structured-clone": "^1.3.0",
    "bumpp": "^10.4.1",
    "eslint": "^10.0.3",
    "lint-staged": "^16.3.3",
    "pnpm": "^10.32.1",
    "simple-git-hooks": "^2.13.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "unbuild": "^3.6.1",
    "vite": "^7.3.1"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged"
  },
  "lint-staged": {
    "*": "eslint --fix"
  }
}
